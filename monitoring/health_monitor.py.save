#!/usr/bin/env python3
import subprocess, time, yaml, datetime, os
from prometheus_client import start_http_server, Gauge

INVENTORY = "inventory/campus.yaml"
LOG_FILE = "monitoring/events.log"
INTERVAL = 10

tunnel_up      = Gauge('tunnel_up',         'Tunnel status 1=up 0=down', ['branch'])
tunnel_latency = Gauge('tunnel_latency_ms', 'Latency in ms',             ['branch'])

def ping(ns, target, count=3):
    cmd = f"ip netns exec {ns} ping -c {count} -W 2 {target}"
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    if result.returncode != 0:
        return None
    for line in result.stdout.splitlines():
        if "rtt" in line:
            return float(line.split('/')[4])
    return None

def log_event(msg):
    ts = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{ts}] {msg}"
    print(line)
    with open(LOG_FILE, "a") as f:
        f.write(line + "\n")

def monitor():
    with open(INVENTORY) as f:
        inv = yaml.safe_load(f)
    hq_ip = none
    prev_state = {}

    print("[*] Starting Prometheus metrics server on port 8000...")
    start_http_server(8000)
    print("[*] Health monitor started — polling every 10s")
    print("[*] Metrics available at http://localhost:8000")

    while True:
        for branch in inv['branches']:
            ns  = branch['namespace']
            bid = branch['id']
            hq_link_ip = branch['link_ip_hq'].split('/')[0latency = ping(ns, hq_link_ip)

            if latency is not None:
                tunnel_up.labels(branch=bid).set(1)
                tunnel_latency.labels(branch=bid).set(round(latency, 2))
                if prev_state.get(bid) == 0:
                    log_event(f"RECOVERY  {bid} → HQ restored ({latency:.1f}ms)")
                else:
                    log_event(f"OK        {bid} → HQ  {latency:.1f} ms")
                prev_state[bid] = 1
            else:
                tunnel_up.labels(branch=bid).set(0)
                tunnel_latency.labels(branch=bid).set(-1)
                if prev_state.get(bid) != 0:
                    log_event(f"FAILOVER  {bid} → HQ UNREACHABLE!")
                prev_state[bid] = 0

        time.sleep(INTERVAL)

if __name__ == "__main__":
    os.makedirs("monitoring", exist_ok=True)
    monitor()
